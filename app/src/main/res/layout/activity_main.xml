<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- 탭(좌 70%) + 아이콘(우 30%) 한 줄 배치 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#1565C0"
        android:orientation="horizontal">

        <!-- 탭: 전체 폭의 70% -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="7"
            android:background="@android:color/transparent"
            app:tabGravity="fill"
            app:tabMode="fixed"
            app:tabSelectedTextColor="#FFFFFF"
            app:tabTextColor="#90CAF9"
            app:tabIndicatorColor="#FFFFFF"
            app:tabIndicatorHeight="3dp">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="개별기업" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="계열집단" />

        </com.google.android.material.tabs.TabLayout>

        <!-- Toolbar: 우측 30% — 돋보기·⋮ 아이콘 전용 -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:background="@android:color/transparent"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
            app:contentInsetStart="0dp"
            app:contentInsetEnd="0dp"
            app:titleTextColor="@android:color/transparent" />

    </LinearLayout>

    <!-- 로딩 인디케이터 (공용) -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="#1565C0"
        android:layout_marginTop="48dp" />

    <!-- ════════════════════════════════════════════ -->
    <!--  [탭 0] 개별기업 컨테이너                        -->
    <!-- ════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/companyContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="visible">

        <LinearLayout
            android:id="@+id/listHeader"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:background="#E3F2FD"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2.4"
                android:text="기업명"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#1565C0"
                android:paddingEnd="6dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="대표자"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#1565C0"
                android:gravity="center"
                android:paddingEnd="4dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.8"
                android:text="사업자번호"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#1565C0"
                android:gravity="center"
                android:paddingEnd="4dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.7"
                android:text="등급"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#1565C0"
                android:gravity="end" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/emptyView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="15sp"
            android:textColor="#9E9E9E"
            android:lineSpacingMultiplier="1.5"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ════════════════════════════════════════════ -->
    <!--  [탭 1] 계열집단 컨테이너                        -->
    <!-- ════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/groupContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/listHeaderGroup"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:background="#E8F5E9"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:text="순위"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="#2E7D32"
                android:gravity="center" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.8"
                android:text="기업집단명"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="#2E7D32"
                android:paddingStart="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="동일인"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="#2E7D32" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:text="계열사"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="#2E7D32"
                android:gravity="center" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="자산총액"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="#2E7D32"
                android:gravity="end" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewGroup"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/emptyViewGroup"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="15sp"
            android:textColor="#9E9E9E"
            android:lineSpacingMultiplier="1.5"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>